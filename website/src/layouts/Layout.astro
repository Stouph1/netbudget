---
import "../styles/globals.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { useTranslations, isRtl, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  pageKind?: "home" | "page";
}

const { locale, title, description, pageKind = "home" } = Astro.props;
const t = useTranslations(locale);
const dir = isRtl(locale) ? "rtl" : "ltr";

const pageTitle = title ?? `NETbudget — ${t("hero.title")}`;
const pageDesc = description ?? t("hero.subtitle");
const ogImage = "/og-image.png";
---

<!doctype html>
<html lang={locale} dir={dir} class="bg-ink-900">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0A0A0C" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" hreflang="x-default" href="https://netbudget.app/" />
    <link rel="alternate" hreflang="fr" href="https://netbudget.app/" />
    <link rel="alternate" hreflang="en" href="https://netbudget.app/en/" />
  </head>
  <body class="font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-mint-500 focus:px-3 focus:py-2 focus:text-ink-900"
    >
      Skip to content
    </a>
    <Nav locale={locale} pageKind={pageKind} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />

    <script>
      // Reveal-on-scroll : ajoute la classe "reveal-visible" aux éléments .reveal
      // dès qu'ils entrent dans le viewport.
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("reveal-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
  </body>
</html>

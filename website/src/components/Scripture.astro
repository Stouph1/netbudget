---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section aria-label="Citation" class="relative">
  <div class="container-app py-14 md:py-16">
    <figure class="mx-auto max-w-3xl text-center reveal">
      <svg
        aria-hidden="true"
        class="mx-auto h-7 w-7 text-mint-400/60"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path d="M9 7c-3.5 0-6 2.5-6 6v4h6v-6H6c0-1.5 1.5-3 3-3V7zm10 0c-3.5 0-6 2.5-6 6v4h6v-6h-3c0-1.5 1.5-3 3-3V7z" />
      </svg>
      <blockquote class="mt-5 text-balance text-base italic leading-relaxed text-text-2 sm:text-lg">
        {t("scripture.verse")}
      </blockquote>
      <figcaption class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-mint-400">
        {t("scripture.ref")}
      </figcaption>
    </figure>
  </div>
</section>

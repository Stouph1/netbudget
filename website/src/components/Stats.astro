---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const stats = [
  { value: "8", label: t("stats.languages") },
  { value: "15", label: t("stats.currencies") },
  { value: "558", label: t("stats.cities") },
  { value: "59", label: t("stats.countries") },
];
---

<section class="border-y border-white/[0.06] bg-white/[0.02]">
  <div class="container-app py-10">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
      {stats.map((s) => (
        <div class="reveal text-center">
          <div class="text-3xl font-bold gradient-text md:text-4xl">{s.value}</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-text-3">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

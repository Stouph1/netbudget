---
// Cadre iPhone réaliste qui affiche une capture d'écran fournie.
// Si l'image n'existe pas (build avant que l'utilisateur l'ait sauvée),
// on affiche un fallback "placeholder" propre plutôt qu'une icône cassée.

interface Props {
  src: string; // chemin de la capture sous /public/, ex: "/screens/budget.png"
  alt: string;
  tilt?: "left" | "right" | "none";
  size?: "sm" | "md" | "lg";
  glow?: boolean;
}

const { src, alt, tilt = "none", size = "md", glow = true } = Astro.props;

const sizeClass = {
  sm: "w-[200px] sm:w-[220px]",
  md: "w-[260px] sm:w-[300px] md:w-[320px]",
  lg: "w-[300px] sm:w-[340px] md:w-[360px]",
}[size];

const tiltClass = {
  left: "md:-rotate-[6deg]",
  right: "md:rotate-[6deg]",
  none: "",
}[tilt];
---

<div class:list={["relative mx-auto transition-transform duration-700", sizeClass, tiltClass]}>
  {glow && (
    <div aria-hidden="true" class="absolute -inset-10 -z-10 rounded-full bg-gradient-to-br from-mint-500/30 via-cyan-400/15 to-transparent blur-3xl"></div>
  )}

  <!-- Bezel iPhone -->
  <div class="relative rounded-[44px] border border-white/15 bg-ink-800 p-2 shadow-[0_30px_80px_-20px_rgba(16,185,129,0.30),0_10px_40px_-10px_rgba(0,0,0,0.6)]">
    <div class="rounded-[36px] overflow-hidden bg-ink-900 aspect-[9/19.5] relative">
      <!-- Dynamic island -->
      <div aria-hidden="true" class="absolute left-1/2 top-2 z-20 h-6 w-24 -translate-x-1/2 rounded-full bg-black/95 ring-1 ring-white/5"></div>

      <!-- Capture -->
      <img
        src={src}
        alt={alt}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
        onerror="this.classList.add('hidden'); const sib = this.nextElementSibling; if (sib) sib.classList.remove('hidden');"
      />

      <!-- Fallback affiché si l'image n'existe pas (this.nextElementSibling) -->
      <div class="hidden absolute inset-0 flex flex-col items-center justify-center gap-3 p-8 text-center bg-gradient-to-br from-midnight-800 to-ink-900">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint-400">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <circle cx="9" cy="9" r="2" />
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
        </svg>
        <p class="text-xs text-text-3">Capture à venir</p>
        <code class="text-[10px] text-text-3 break-all opacity-60">{src}</code>
      </div>
    </div>
  </div>
</div>

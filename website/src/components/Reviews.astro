---
import { useTranslations, type Locale } from "../i18n/utils";
import { getReviews, type Review } from "../lib/reviews";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Fetch au build. On n'affiche que de VRAIS avis App Store, jamais de fakes.
let reviews: Review[] = [];
try {
  reviews = await getReviews();
} catch {
  reviews = [];
}

const count = reviews.length;
// On affiche dès qu'il y a au moins 1 avis.
const show = count >= 1;
// Marquee horizontal infini seulement si on a assez d'avis pour rendre la boucle
// non répétitive (sinon le visiteur verrait juste les 2 mêmes cartes passer en
// boucle). Sous ce seuil, on bascule sur une grille statique centrée.
const useMarquee = count >= 6;

// Dédoublage pour le marquee infini (translate-x:-50 % atterrit pile sur la 2e copie).
const loop = useMarquee ? [...reviews, ...reviews] : reviews;

// Drapeau emoji à partir du code pays ISO-2.
function flag(cc: string): string {
  if (!cc || cc.length !== 2) return "";
  const base = 127397;
  return String.fromCodePoint(...cc.toUpperCase().split("").map((c) => base + c.charCodeAt(0)));
}

function truncate(s: string, n: number) {
  return s.length > n ? s.slice(0, n - 1).trimEnd() + "…" : s;
}
---

{show && (
<section id="reviews" class="relative overflow-hidden">
  <div class="py-20 md:py-24">
    <div class="container-app text-center reveal">
      <span class="eyebrow">{t("reviews.eyebrow")}</span>
      <h2 class="heading-2 mt-4 text-balance">{t("reviews.title")}</h2>
      <p class="body-lg mx-auto mt-4 max-w-2xl text-balance">{t("reviews.subtitle")}</p>
    </div>

    {useMarquee ? (
      <div
        class="relative mt-12 [mask-image:linear-gradient(90deg,transparent,#000_10%,#000_90%,transparent)] [mask-mode:luminance]"
        data-marquee-root
      >
        <div class="flex w-max gap-4 animate-marquee" data-marquee-track>
          {loop.map((r) => (
            <article class="w-[300px] shrink-0 rounded-2xl border border-white/10 bg-white/[0.04] p-5 text-left transition hover:border-mint-500/30">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="grid h-9 w-9 place-items-center rounded-full bg-gradient-to-br from-mint-500/30 to-cyan-400/20 text-xs font-bold text-mint-300">
                    {(r.author || "?").slice(0, 1).toUpperCase()}
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-text-1">{r.author}</div>
                    <div class="text-[11px] text-text-3">{flag(r.countryCode)} {r.countryCode}</div>
                  </div>
                </div>
                <div class="flex gap-0.5 text-cyan-300">
                  {Array.from({ length: 5 }).map((_, k) => (
                    <svg width="12" height="12" viewBox="0 0 24 24" fill={k < r.rating ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
              </div>
              {r.title && <div class="mt-3 text-sm font-semibold text-text-1">{r.title}</div>}
              <p class="mt-2 text-sm leading-relaxed text-text-2">{truncate(r.text, 180)}</p>
            </article>
          ))}
        </div>
      </div>
    ) : (
      <div class="container-app mt-12">
        <div class="mx-auto grid max-w-4xl gap-5 sm:grid-cols-2">
          {reviews.map((r, i) => (
            <article class="rounded-2xl border border-white/10 bg-white/[0.04] p-6 text-left transition hover:border-mint-500/30 reveal" style={`animation-delay: ${i * 80}ms`}>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                  <div class="grid h-10 w-10 place-items-center rounded-full bg-gradient-to-br from-mint-500/30 to-cyan-400/20 text-sm font-bold text-mint-300">
                    {(r.author || "?").slice(0, 1).toUpperCase()}
                  </div>
                  <div>
                    <div class="text-sm font-semibold text-text-1">{r.author}</div>
                    <div class="text-[11px] text-text-3">{flag(r.countryCode)} {r.countryCode}</div>
                  </div>
                </div>
                <div class="flex gap-0.5 text-cyan-300">
                  {Array.from({ length: 5 }).map((_, k) => (
                    <svg width="13" height="13" viewBox="0 0 24 24" fill={k < r.rating ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ))}
                </div>
              </div>
              {r.title && <div class="mt-4 text-base font-semibold text-text-1">{r.title}</div>}
              <p class="mt-2 text-sm leading-relaxed text-text-2">{r.text}</p>
            </article>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
)}

<script>
  // Pause au survol / focus clavier pour l'accessibilité (marquee uniquement)
  const root = document.querySelector("[data-marquee-root]");
  const track = document.querySelector<HTMLElement>("[data-marquee-track]");
  if (root && track) {
    root.addEventListener("mouseenter", () => { track.style.animationPlayState = "paused"; });
    root.addEventListener("mouseleave", () => { track.style.animationPlayState = "running"; });
  }
</script>

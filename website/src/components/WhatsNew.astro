---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const items = ["item1", "item2", "item3", "item4", "item5", "item6"];
---

<section id="whatsnew" class="relative">
  <div class="container-app py-20 md:py-28">
    <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-mint-500/[0.08] via-white/[0.02] to-transparent p-8 md:p-14">
      <div class="grid items-start gap-10 md:grid-cols-[1fr_1.5fr]">
        <div class="reveal">
          <span class="eyebrow">{t("whatsnew.eyebrow")}</span>
          <h2 class="heading-2 mt-4 text-balance">{t("whatsnew.title")}</h2>
          <p class="body-lg mt-4">{t("whatsnew.subtitle")}</p>
        </div>

        <ol class="space-y-4">
          {items.map((id, i) => (
            <li class="group flex gap-4 rounded-2xl border border-white/10 bg-white/[0.04] p-5 transition hover:border-white/20 hover:bg-white/[0.06] reveal" style={`animation-delay: ${i * 70}ms`}>
              <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-full bg-mint-500/15 text-xs font-bold text-mint-400 ring-1 ring-mint-500/30">
                {i + 1}
              </span>
              <div>
                <h3 class="text-base font-semibold text-text-1">{t(`whatsnew.${id}.title`)}</h3>
                <p class="mt-1 text-sm text-text-2">{t(`whatsnew.${id}.text`)}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </div>
</section>

---
import AppMockup from "./AppMockup.astro";
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative overflow-hidden">
  <!-- Soft conic gradient background -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-60">
    <div class="absolute -top-32 left-1/2 h-[600px] w-[1200px] -translate-x-1/2 rounded-full bg-gradient-radial from-gold-500/20 via-amber-500/5 to-transparent blur-3xl"></div>
  </div>

  <div class="container-app pt-12 pb-16 md:pt-24 md:pb-24">
    <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
      <div class="space-y-7 text-center md:text-left">
        <span class="eyebrow">{t("hero.eyebrow")}</span>
        <h1 class="heading-1 text-balance">
          <span set:html={t("hero.title").replace("?", '<span class="gradient-text">?</span>')} />
        </h1>
        <p class="body-lg max-w-xl text-balance md:max-w-none">{t("hero.subtitle")}</p>

        <div class="flex flex-wrap items-center justify-center gap-3 md:justify-start">
          <a id="download" href="https://apps.apple.com/" target="_blank" rel="noopener" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16.365 1.43c0 1.14-.41 2.16-1.22 3.04-.96 1.04-2.06 1.65-3.27 1.55-.13-1.12.42-2.27 1.27-3.16.86-.91 2.16-1.5 3.22-1.43zm3.93 17.66c-.46 1.08-1.01 2.11-1.65 3.07-.86 1.27-1.56 2.15-2.1 2.64-.83.77-1.72 1.17-2.67 1.19-.68.01-1.5-.19-2.45-.6-.95-.4-1.82-.6-2.62-.6-.84 0-1.74.2-2.7.6-.96.41-1.74.62-2.34.64-.92.04-1.83-.37-2.74-1.22-.58-.55-1.32-1.46-2.21-2.74-.95-1.36-1.73-2.95-2.34-4.76C.79 15.36.45 13.69.45 12.07c0-1.85.4-3.45 1.2-4.79.63-1.08 1.47-1.93 2.52-2.55 1.05-.62 2.18-.94 3.4-.96.72 0 1.66.22 2.83.65 1.17.43 1.93.65 2.27.65.26 0 1.1-.26 2.52-.78 1.34-.48 2.47-.68 3.4-.6 2.51.2 4.39 1.19 5.66 2.96-2.25 1.36-3.36 3.27-3.34 5.71.02 1.9.7 3.48 2.05 4.74.61.58 1.29 1.02 2.05 1.34-.17.49-.35.96-.55 1.42z" />
            </svg>
            {t("hero.cta.appstore")}
          </a>
          <a href="#features" class="btn-secondary">
            {t("hero.cta.learn")}
          </a>
        </div>

        <p class="text-xs text-text-3">{t("hero.note")}</p>
      </div>

      <div class="flex justify-center md:justify-end">
        <AppMockup />
      </div>
    </div>
  </div>
</section>

---
import AppMockup from "./AppMockup.astro";
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative overflow-hidden">
  <!-- Soft conic gradient background -->
  <div aria-hidden="true" class="absolute inset-0 -z-10 opacity-60">
    <div class="absolute -top-32 left-1/2 h-[600px] w-[1200px] -translate-x-1/2 rounded-full bg-gradient-radial from-mint-500/20 via-cyan-400/5 to-transparent blur-3xl"></div>
  </div>

  <div class="container-app pt-12 pb-16 md:pt-24 md:pb-24">
    <div class="grid items-center gap-12 md:grid-cols-2 md:gap-16">
      <div class="space-y-7 text-center md:text-left">
        <span class="eyebrow">{t("hero.eyebrow")}</span>
        <h1 class="heading-1 text-balance">
          <span set:html={t("hero.title").replace("?", '<span class="gradient-text">?</span>')} />
        </h1>
        <p class="body-lg max-w-xl text-balance md:max-w-none">{t("hero.subtitle")}</p>

        <div class="flex flex-wrap items-center justify-center gap-3 md:justify-start">
          <a id="download" href="https://apps.apple.com/app/netbudget/id6763551701" target="_blank" rel="noopener" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.05 14.44c.02 2.15 1.94 2.76 1.95 2.78-.02.05-.33 1.13-1.08 2.24-.64.95-1.31 1.9-2.37 1.92-1.07.02-1.38-.65-2.59-.65-1.21 0-1.56.63-2.57.67-1.03.04-1.81-1.03-2.46-1.97C6.59 16.48 5.59 12.99 6.97 10.61c.69-1.17 1.92-1.92 3.25-1.95 1.02-.02 1.97.69 2.59.69.62 0 1.78-.85 3-.72.5.02 1.94.21 2.85 1.54-.07.05-1.71.96-1.69 3.27zM14.77 7.34c.55-.67.91-1.6.81-2.51-.78.03-1.73.52-2.29 1.2-.52.6-.96 1.54-.85 2.43.88.07 1.77-.47 2.33-1.12z"/>
            </svg>
            {t("hero.cta.appstore")}
          </a>
          <a href="#features" class="btn-secondary">
            {t("hero.cta.learn")}
          </a>
        </div>

        <p class="text-xs text-text-3">{t("hero.note")}</p>
      </div>

      <div class="flex justify-center md:justify-end">
        <AppMockup />
      </div>
    </div>
  </div>
</section>

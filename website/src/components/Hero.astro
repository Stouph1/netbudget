---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

const videoSrc = locale === "fr"
  ? "/videos/netbudget-spot-fr.mp4"
  : "/videos/netbudget-spot-en.mp4";
---

<section class="relative overflow-hidden">
  <!-- Layered ambient glow behind the hero (mint + cyan radial) -->
  <div aria-hidden="true" class="absolute inset-0 -z-10">
    <div
      class="absolute -top-40 left-1/2 h-[700px] w-[1300px] -translate-x-1/2 rounded-full bg-gradient-radial from-mint-500/25 via-cyan-400/10 to-transparent blur-3xl"
    >
    </div>
  </div>

  <div class="container-app pt-10 pb-12 md:pt-20 md:pb-24">
    <div class="grid items-center gap-10 md:grid-cols-[1.05fr_0.95fr] md:gap-14">
      <!-- Left: copy + CTAs -->
      <div class="space-y-7 text-center md:text-left">
        <span class="eyebrow">{t("hero.eyebrow")}</span>

        <h1
          class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl leading-[1.05] text-balance"
        >
          {t("hero.title")}{" "}
          <span class="gradient-text">{t("hero.title.accent")}</span>{t("hero.title.suffix")}
        </h1>

        <p class="body-lg max-w-xl text-balance md:max-w-none">{t("hero.subtitle")}</p>

        <div class="flex flex-wrap items-center justify-center gap-3 md:justify-start">
          <a
            id="download"
            href="https://apps.apple.com/app/netbudget/id6763551701"
            target="_blank"
            rel="noopener"
            class="btn-primary"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M17.05 14.44c.02 2.15 1.94 2.76 1.95 2.78-.02.05-.33 1.13-1.08 2.24-.64.95-1.31 1.9-2.37 1.92-1.07.02-1.38-.65-2.59-.65-1.21 0-1.56.63-2.57.67-1.03.04-1.81-1.03-2.46-1.97C6.59 16.48 5.59 12.99 6.97 10.61c.69-1.17 1.92-1.92 3.25-1.95 1.02-.02 1.97.69 2.59.69.62 0 1.78-.85 3-.72.5.02 1.94.21 2.85 1.54-.07.05-1.71.96-1.69 3.27zM14.77 7.34c.55-.67.91-1.6.81-2.51-.78.03-1.73.52-2.29 1.2-.52.6-.96 1.54-.85 2.43.88.07 1.77-.47 2.33-1.12z"
              ></path>
            </svg>
            {t("hero.cta.appstore")}
          </a>
          <a href="#features" class="btn-secondary">
            {t("hero.cta.learn")}
          </a>
        </div>

        <p class="text-xs text-text-3">{t("hero.note")}</p>
      </div>

      <!-- Right: autoplay spot video in a phone-like frame (Apple/Tesla style) -->
      <div class="relative flex justify-center md:justify-end">
        <!-- Outer breathing glow -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -inset-6 -z-10 rounded-[60px] bg-mint-500/15 blur-3xl animate-float"
        >
        </div>

        <div
          class="group/spot relative aspect-[9/16] w-full max-w-[300px] overflow-hidden rounded-[44px] border border-midnight-600/70 bg-midnight-900 shadow-[0_50px_100px_-20px_rgba(0,0,0,0.75),0_0_70px_-10px_rgba(110,231,183,0.35)] sm:max-w-[340px] md:max-w-[420px] lg:max-w-[460px]"
        >
          <video
            id="hero-spot-video"
            class="h-full w-full object-cover"
            src={videoSrc}
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            aria-label={t("spot.title")}
          >
          </video>

          <!-- Sound toggle (top-right) -->
          <button
            id="hero-spot-sound"
            type="button"
            aria-label={t("spot.unmute")}
            data-unmute-label={t("spot.unmute")}
            data-mute-label={t("spot.mute")}
            class="absolute right-3 top-3 z-10 flex h-11 w-11 items-center justify-center rounded-full border border-white/15 bg-black/55 text-white backdrop-blur-md transition-all hover:scale-105 hover:bg-black/70 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-mint-300"
          >
            <svg
              id="hero-icon-muted"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <line x1="22" y1="9" x2="16" y2="15"></line>
              <line x1="16" y1="9" x2="22" y2="15"></line>
            </svg>
            <svg
              id="hero-icon-unmuted"
              class="hidden"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
            </svg>
          </button>

          <!-- Bottom gradient for visual finish over the video tail -->
          <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-black/40 to-transparent"
          >
          </div>
        </div>

        <!-- Small "Tap for sound" hint floating beside the video -->
        <div
          class="pointer-events-none absolute -bottom-3 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-full border border-midnight-600/70 bg-midnight-800/80 px-3 py-1 text-xs font-medium text-text-2 backdrop-blur"
        >
          🔊 {t("spot.unmute")}
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const video = document.getElementById("hero-spot-video");
    const btn = document.getElementById("hero-spot-sound");
    const iconMuted = document.getElementById("hero-icon-muted");
    const iconUnmuted = document.getElementById("hero-icon-unmuted");
    if (!video || !btn || !iconMuted || !iconUnmuted) return;
    const muteLabel = btn.getAttribute("data-mute-label") || "Mute";
    const unmuteLabel = btn.getAttribute("data-unmute-label") || "Unmute";

    function updateUI() {
      if (video.muted) {
        iconMuted.classList.remove("hidden");
        iconUnmuted.classList.add("hidden");
        btn.setAttribute("aria-label", unmuteLabel);
      } else {
        iconMuted.classList.add("hidden");
        iconUnmuted.classList.remove("hidden");
        btn.setAttribute("aria-label", muteLabel);
      }
    }

    btn.addEventListener("click", function () {
      video.muted = !video.muted;
      if (!video.muted) {
        video.volume = 1;
        video.currentTime = 0;
        const p = video.play();
        if (p && typeof p.catch === "function") p.catch(function () {});
      }
      updateUI();
    });

    // Pause when scrolled out of view, resume when back
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              const p = video.play();
              if (p && typeof p.catch === "function") p.catch(function () {});
            } else {
              video.pause();
            }
          });
        },
        { threshold: 0.3 },
      );
      io.observe(video);
    }

    updateUI();
  })();
</script>
